# Renomeie pra .env.sonar e preencha
# Não commite esse arquivo! Adicione ao .gitignore

# Token gerado em: http://localhost:9000 → My Account → Security → Generate Token
SONAR_TOKEN=cole_seu_token_aqui

# URL do seu SonarQube local
SONAR_HOST=http://localhost:9000

# Identificador único do seu projeto local (use seu user pra não conflitar com a equipe)
SONAR_PROJECT_KEY=meu-projeto-local-seunome
SONAR_PROJECT_NAME="Meu Projeto (local)"

# Opcional: força uma solution específica (senão autodetecta o primeiro .sln)
# SOLUTION_FILE=MinhaApp.sln
